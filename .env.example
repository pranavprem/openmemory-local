# Memory Service Configuration
# =============================
# Copy to .env and customize.

# Mode: "mem0" (default) or "openmemory"
#   mem0       = Qdrant only. Mem0 OpenClaw plugin handles capture/recall.
#   openmemory = Qdrant + OpenMemory API + Dashboard UI.
MEMORY_MODE=mem0

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Use a named volume (default) or bind mount for NAS:
#   Named volume: qdrant_data
#   Bind mount:   /volume1/docker/neo-memory/qdrant
QDRANT_DATA_DIR=qdrant_data

# OpenMemory (only used when MEMORY_MODE=openmemory)
OPENMEMORY_USER=pranav
OPENMEMORY_API_KEY=openmemory-local
OPENMEMORY_API_PORT=8765
OPENMEMORY_UI_PORT=3000

# Network
NAS_IP=10.0.0.116
NAS_USER=Pranav
NAS_DEPLOY_DIR=/volume1/docker/neo-memory
